<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản lý sản phẩm</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .product-img { width: 80px; height: 80px; object-fit: cover; border-radius: 8px; }
        .table align-middle td, .table align-middle th { vertical-align: middle; }
        /* Đảm bảo form tìm kiếm không quá rộng trên màn hình lớn */
        .search-section { max-width: 600px; }
    </style>
</head>
<body class="bg-light">
    <div class="container py-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="text-primary fw-bold">📦 Quản lý sản phẩm</h1>
            <a href="/add" class="btn btn-success shadow-sm">
                <i class="bi bi-plus-lg"></i> + Thêm sản phẩm mới
            </a>
        </div>

        <div class="search-section mb-4">
            <form action="/" method="GET">
                <div class="input-group shadow-sm">
                    <input 
                        type="text" 
                        name="search" 
                        class="form-control" 
                        placeholder="Nhập tên sản phẩm cần tìm..." 
                        value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>"
                        aria-label="Search"
                    >
                    <button class="btn btn-primary px-4" type="submit">
                        Tìm kiếm
                    </button>
                    <% if (typeof searchQuery !== 'undefined' && searchQuery) { %>
                        <a href="/" class="btn btn-outline-secondary">
                            Hủy lọc
                        </a>
                    <% } %>
                </div>
                <% if (typeof searchQuery !== 'undefined' && searchQuery) { %>
                    <div class="form-text mt-2 text-muted">
                        Đang hiển thị kết quả cho: <strong>"<%= searchQuery %>"</strong>
                    </div>
                <% } %>
            </form>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th class="ps-4">Hình ảnh</th>
                                <th>Tên sản phẩm</th>
                                <th>Giá (VNĐ)</th>
                                <th>Tồn kho</th>
                                <th class="text-center">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (products.length > 0) { %>
                                <% products.forEach(product => { %>
                                    <tr>
                                        <td class="ps-4">
                                            <img src="<%= product.url_image || 'https://via.placeholder.com/80' %>" 
                                                 class="product-img border" alt="Sản phẩm">
                                        </td>
                                        <td class="fw-bold text-dark"><%= product.name %></td>
                                        <td class="text-danger fw-bold">
                                            <%= product.price ? product.price.toLocaleString() : 0 %>
                                        </td>
                                        <td>
                                            <span class="badge bg-info text-dark">
                                                <%= product.unit_in_stock %>
                                            </span>
                                        </td>
                                        <td class="text-center">
                                            <div class="btn-group shadow-sm">
                                                <a href="/detail/<%= product.id %>" class="btn btn-outline-primary btn-sm">Xem</a>
                                                <a href="/edit/<%= product.id %>" class="btn btn-outline-warning btn-sm">Sửa</a>
                                                <a href="/delete/<%= product.id %>" 
                                                   class="btn btn-outline-danger btn-sm" 
                                                   onclick="return confirm('Bạn có chắc chắn muốn xóa sản phẩm này?')">Xóa</a>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="5" class="text-center py-5 text-muted">
                                        <p class="mb-0">Không tìm thấy sản phẩm nào.</p>
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>